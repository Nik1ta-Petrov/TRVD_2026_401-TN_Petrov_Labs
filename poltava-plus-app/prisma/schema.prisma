generator client {
  provider = "prisma-client-js"
}

// connect PostgreSQL (Supabase)
datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  
  password  String   
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Subscription {
  id              String   @id @default(cuid())
  telegramId      String
  groupNumber     Int
  subscribeOutage Boolean  @default(true)
  subscribeAlert  Boolean  @default(false)
  createdAt       DateTime @default(now())
  
  userEmail       String   
}