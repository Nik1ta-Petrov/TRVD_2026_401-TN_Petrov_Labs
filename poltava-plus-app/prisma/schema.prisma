generator client {
  provider = "prisma-client-js"
}

// connect PostgreSQL (Supabase)
datasource db {
  provider = "postgresql"
}

model Subscription {
  id              String   @id @default(cuid())
  telegramId      String   @unique
  username        String?
  groupNumber     Int?     
  subscribeOutage Boolean  @default(false) 
  subscribeAlert  Boolean  @default(false) 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}